# JoyPhone 服务端 .env 模板 — 复制为 server/.env 后按需改值
# (.env 已被 .gitignore,本地密钥/IP 不会被提交)
#
# 优先级:真实环境变量 > 此文件内的变量(run_uvicorn_detached.py 不会自己
# load_dotenv,所以用 uv run / dotenv / direnv / 手动 source 加载后再启进程)

# ============ LLM (MiniMax OpenAI 兼容) ============
LLM_API_KEY=
LLM_BASE_URL=https://api.minimaxi.com/v1
# 可选模型: MiniMax-M3 / MiniMax-M2.5 / MiniMax-M2.5-highspeed / MiniMax-M2
# 2026-07-23 benchmark 实测: MiniMax-M3 + thinking=disabled
#   延迟 1.3s(vs M2.5-highspeed 5.6s)
LLM_MODEL=MiniMax-M3

# ============ 服务端监听(被 run_uvicorn_detached.py 读取) ============
# 安卓真机连服务端时,WS_URL(在 android/local.properties 里配)要和这里保持一致。
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ============ 调试 / 路径覆写(已被 app.main 与 connection 读取) ============
# 留空 = 用默认值。改之前看 server/app/infra/config.py / app/main.py。

# PHONEAGENT_FAKE_LLM=true      # 跳过真 LLM,用 FakeLLM(每次返回 "read");调试时省 token
# PHONEAGENT_MAX_STEPS=40       # 单任务最大步数(超过强制 abort)
# SKILL_CACHE_PATH=data/skill_cache.json   # 技能回放缓存文件路径
# PHONEAGENT_LOG_DIR=logs       # 落 uvicorn.log / llm.log / comm.log 的目录
